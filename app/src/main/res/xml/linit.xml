<?xml version="1.0" encoding="utf-8"?>
<lint xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Disable specific rules -->
    <issue id="HardcodedText" severity="ignore"/>
    <issue id="MissingTranslation" severity="ignore"/>

    <!-- Change severity levels -->
    <issue id="UnusedResources" severity="warning"/>
    <issue id="TypographyDashes" severity="error"/>

    <!-- Configure rules with options -->
    <issue id="MissingQuantity">
        <ignore path="res/values-pl/strings.xml"/>
    </issue>

    <!-- Treat these as errors (will fail build) -->
    <issue id="NewApi" severity="error"/>
    <issue id="Override" severity="error"/>

    <!-- Ignore these rules -->
    <issue id="MissingTranslation" severity="ignore"/>

    <!-- Warn but don't fail build -->
    <issue id="UnusedResources" severity="warning"/>
</lint>
